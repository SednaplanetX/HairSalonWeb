    <h2 class="section-title">Our Hair Styles</h2>
    <div class="styles-grid">
      <div class="style-card">
        <div class="style-image"><img src="https://th.bing.com/th/id/OIP.7IW5GALwwwNIR1eWlLnUYwHaLH?w=203&h=304&c=7&r=0&o=7&pid=1.7&rm=3" alt="Modern Bob"></div>
